<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">
<suite name="Suite">

	<parameter name="websiteURL" value="https://opensource-demo.orangehrmlive.com/"></parameter>
	<parameter name="username" value="Admin"></parameter>
	<parameter name="password" value="admin123"></parameter>
	<test name="LoginValidation">
		<parameter name="browserName" value="chrome"></parameter>
		<classes>
			<class name="testngPractice.TestNG.ParameterAnnotation_OrangeHRM" >
			<methods>
				<include name="GetBrowser" />
				<include name="LaunchApplication" />
				<include name="LoginWithCredentials" />
				<include name="VerifyLogin" />
			</methods>
			</class>
		</classes>
	</test>


	<test name="MyInfoValidation">
		<parameter name="browserName" value="edge"></parameter>
		<classes>
			<class name="testngPractice.TestNG.ParameterAnnotation_OrangeHRM" >
			<methods>
				<include name="GetBrowser" />
				<include name="LaunchApplication" />
				<include name="LoginWithCredentials" />
				<include name="NavigateToMyinfoTab" />
				<include name="VerifyMyinfo" />
			</methods>
			</class>
		</classes>
	</test>
</suite>